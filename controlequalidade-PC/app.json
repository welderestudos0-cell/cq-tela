{
  "expo": {
    "name": "Controle de Qualidade",
    "slug": "agrosolo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LOGO_CQ.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/LOGO_CQ.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/LOGO_CQ.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE"
      ],
      "usesCleartextTraffic": true,
      "networkSecurityConfig": "./network_security_config.xml",
      "package": "com.cqagrodan.agrosoloapp"
    },
    "web": {
      "favicon": "./assets/agrosolologo.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "networkSecurityConfig": "./network_security_config.xml"
          }
        }
      ],
      "expo-asset"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3648a12d-6e9e-46d7-b095-f11e7823ba2c",
      "checkOnLaunch": "ALWAYS",
      "fallbackToCacheTimeout": 30000
    },
    "extra": {
      "eas": {
        "projectId": "3648a12d-6e9e-46d7-b095-f11e7823ba2c"
      }
    }
  }
}
